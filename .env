# Smart Classroom & Timetable Scheduler - Environment Configuration

# Database Configuration
# MySQL Database (Recommended)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=smart_classroom

# Option 1: Local MongoDB (if installed)
# MONGODB_URI=mongodb://localhost:27017/smart_classroom

# Option 2: MongoDB Atlas (Cloud) - FREE TIER
# Replace with your own connection string from https://www.mongodb.com/cloud/atlas
# MONGODB_URI=mongodb+srv://edusmart:edusmart123@cluster0.mongodb.net/smart_classroom?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (for future token-based auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# API Configuration
API_BASE_URL=http://localhost:3000
